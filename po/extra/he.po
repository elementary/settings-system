#: data/system.metainfo.xml.in:10
msgid "System"
msgstr "מערכת"

#: data/system.metainfo.xml.in:11
msgid "View operating system and hardware information"
msgstr "צפייה במידע חומרה ומערכת ההפעלה"

#: data/system.metainfo.xml.in:37
msgid "elementary, Inc."
msgstr "elementary בע״מ."

#: data/system.metainfo.xml.in:45 data/system.metainfo.xml.in:57
#: data/system.metainfo.xml.in:71 data/system.metainfo.xml.in:84
#: data/system.metainfo.xml.in:99 data/system.metainfo.xml.in:116
#: data/system.metainfo.xml.in:139 data/system.metainfo.xml.in:155
#: data/system.metainfo.xml.in:164 data/system.metainfo.xml.in:192
msgid "Minor updates:"
msgstr "עדכונים משניים:"

#: data/system.metainfo.xml.in:47 data/system.metainfo.xml.in:60
#: data/system.metainfo.xml.in:73 data/system.metainfo.xml.in:86
#: data/system.metainfo.xml.in:101 data/system.metainfo.xml.in:119
#: data/system.metainfo.xml.in:143 data/system.metainfo.xml.in:157
#: data/system.metainfo.xml.in:168 data/system.metainfo.xml.in:196
msgid "Updated translations"
msgstr "תרגומים עודכנו"

#: data/system.metainfo.xml.in:59
msgid "Screen reader improvements"
msgstr "שיפורים למקריא מסך"

#: data/system.metainfo.xml.in:111 data/system.metainfo.xml.in:135
#: data/system.metainfo.xml.in:150
msgid "New features:"
msgstr "יכולות חדשות:"

#: data/system.metainfo.xml.in:113
msgid "Manage Operating System updates, including automatic updates"
msgstr "ניהול עדכוני מערכת ההפעלה, כולל עדכונים אוטומטיים"

#: data/system.metainfo.xml.in:114
msgid "Manage additional drivers"
msgstr "ניהול מנהלי התקנים נוספים"

#: data/system.metainfo.xml.in:118
msgid "Improve operating system image for other Linux distributions"
msgstr "תמונת מערכת ההפעלה השתפרה להפצות לינוקס אחרות"

#: data/system.metainfo.xml.in:137
msgid "Add a button to restart to firmware setup"
msgstr "נוסף כפתור להפעלה מחדש ישירות להגדרות קושחה"

#: data/system.metainfo.xml.in:141
msgid "Get more accurate memory and storage information"
msgstr "קבלת מידע מדויק יותר על פרטי הזיכרון והאחסון"

#: data/system.metainfo.xml.in:142
msgid "Handle Ryzen CPU and AMD GPU vendor string"
msgstr "טיפול במחרוזות יצרן למעבדי Ryzen ומעבדים גרפיים של AMD"

#: data/system.metainfo.xml.in:152
msgid "Added support for dark style manufacturer logos"
msgstr "נוספה תמיכה בלוגואים של יצרנים בסגנון כהה"

#: data/system.metainfo.xml.in:153
msgid "Added support for offline firmware updates"
msgstr "נוספה תמיכה בעדכוני קושחה בלתי מקוונים"

#: data/system.metainfo.xml.in:166
msgid "Use formatted device name when available"
msgstr "ייעשה שימוש בשם מסוגנן למכשיר כשיש שם כזה"

#: data/system.metainfo.xml.in:167
msgid "Display more information for certain GPUs, including Intel® Xe Graphics"
msgstr "הצגת מידע נוסף על מעבדים גרפיים מסוימים לרבות Intel® Xe Graphics"

#: data/system.metainfo.xml.in:175
msgid "Redesign and new features:"
msgstr "עיצוב מחדש ויכולות חדשות:"

#: data/system.metainfo.xml.in:177
msgid "Rename from About to System"
msgstr "שינוי שם מ„על אודות” ל„מערכת”"

#: data/system.metainfo.xml.in:178
msgid "Split Hardware and Operating System info into their own tabs"
msgstr "פיצול פרטי חומרה ומערכת הפעלה ללשוניות עצמאיות"

#: data/system.metainfo.xml.in:179
msgid "Redesign the Operating System tab with clearer links and buttons"
msgstr "עיצוב מחדש של לשונית מערכת ההפעלה ונוספו קישורים וכפתורים ברורים יותר"

#: data/system.metainfo.xml.in:180
msgid "Add a Firmware view to manage device firmware updates"
msgstr "הוספת תצוגת קושחה כדי לנהל את עדכוני קושחות ההתקנים"

#: data/system.metainfo.xml.in:182
msgid "More information:"
msgstr "מידע נוסף:"

#: data/system.metainfo.xml.in:184
msgid "Provide information for ARM CPUs"
msgstr "אספקת מידע לסוגים נוספים של מעבדי ARM"

#: data/system.metainfo.xml.in:185
msgid "Provide information for more types of Graphics"
msgstr "אספקת מידע לסוגים נוספים של גרפיקה"

#: data/system.metainfo.xml.in:187
msgid "Fixes:"
msgstr "תיקונים:"

#: data/system.metainfo.xml.in:189
msgid "Fix an issue where the view was destroyed early when navigating away"
msgstr "תוקנה תקלה בה התצוגה הושמדה מוקדם מדי בעת ניווט אל מחוצה לה"

#: data/system.metainfo.xml.in:190
msgid "Fix system memory calculation"
msgstr "חישוב זיכרון המערכת תוקן"

#: data/system.metainfo.xml.in:194
msgid "Ellipsize long hardware names"
msgstr "שמות רכיבי חומרה ארוכים מקוצרים"

#: data/system.metainfo.xml.in:195
msgid "Performance improvements"
msgstr "שיפורי ביצועים"

#~ msgid "About"
#~ msgstr "על אודות"
